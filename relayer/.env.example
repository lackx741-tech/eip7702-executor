# Relayer private key — this wallet pays gas and receives the fee from native sweeps
RELAYER_PRIVATE_KEY=0x

# RPC endpoints (public nodes are used as fallback if omitted)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
MAINNET_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=

# HTTP port (default: 3001)
PORT=3001
